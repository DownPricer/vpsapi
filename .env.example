# Serveur (le fichier `.env` est chargé au démarrage via `dotenv` dans `src/server.ts`)
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vtc_core_api?schema=public

# Clé API Distance Matrix (DistanceMatrix.ai « accurate » — même host que `api.distancematrix.ai`)
DISTANCE_MATRIX_API_KEY=

# Origines autorisées (CORS), séparées par des virgules. Vide = réflexion selon NODE_ENV
CORS_ORIGINS=http://localhost:3000

# Locataire par défaut si l’en-tête X-Tenant-ID est absent (dev uniquement recommandé)
DEFAULT_TENANT_ID=default

# SMTP (serveur d’envoi — partagé entre locataires)
# Destinataire des notifications opérateur : obligatoirement `smtp.toEmail` dans le JSON du tenant (ex. clients/default.json).
# Ce doit être une vraie boîte que vous consultez (pas une adresse @example.com).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
# Validation TLS certificat SMTP (1 recommand�). Mettre 0 uniquement en debug local si erreur certificat auto-sign�.
SMTP_TLS_REJECT_UNAUTHORIZED=1
# Expéditeur si non défini dans le JSON locataire (smtp.fromEmail)
MAIL_FROM=
MAIL_REPLY_TO=
# Copie cachée optionnelle pour chaque envoi opérateur
MAIL_TO_COPY=

# Accusé client (devis / réservation) : 1/true ou 0/false ; surchargé par tenant.smtp.sendCustomerConfirmation si défini
MAIL_SEND_CUSTOMER_CONFIRMATION=1

# URL du site affichée dans les e-mails (sinon tenant.branding.siteUrl)
PUBLIC_SITE_URL=

# Auth opérateurs (JWT)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=1209600

# URL dashboard utilisée dans les e-mails "Voir la demande"
DASHBOARD_BASE_URL=https://app.sitereadyshd.fr

# Seed optionnel d'un premier opérateur admin
SEED_OPERATOR_TENANT_ID=default
SEED_OPERATOR_EMAIL=admin@example.com
SEED_OPERATOR_PASSWORD=ChangeMeNow123!

